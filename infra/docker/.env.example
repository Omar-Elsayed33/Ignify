# ============================================================
# IGNIFY — Environment Template (Development)
# Copy this file to .env and fill in your values.
# Never commit .env — only commit this file.
# ============================================================

# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=ignify
POSTGRES_PASSWORD=ignify_dev_2024
POSTGRES_DB=ignify
DATABASE_URL=postgresql+asyncpg://ignify:ignify_dev_2024@postgres:5432/ignify

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── App ────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=dev-only-secret-key-change-in-production-64-chars-aaaaaabbbbbbcccccc

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3010","http://localhost:80","http://localhost:8000"]

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Ignify
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# ─── Storage (MinIO — S3-compatible) ────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=ignify
MINIO_SECRET_KEY=ignify_minio_2024
MINIO_BUCKET=ignify-assets
MINIO_PUBLIC_HOST=localhost:9000

# ─── Email (SMTP) ───────────────────────────────────────────
# Leave blank in dev — emails print to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Ignify <no-reply@ignify.ai>
EMAIL_VERIFICATION_REQUIRED=false
FRONTEND_URL=http://localhost:3000

# ─── LLM Gateway — OpenRouter ───────────────────────────────
# OPENROUTER_MANAGER_KEY  →  provisioning only ("Manage keys" permission).
#   Go to https://openrouter.ai/settings/keys, create a key, enable "Manage keys".
#   Used to create/update/delete per-tenant sub-keys. NEVER used for inference.
#   If left blank, provisioning is skipped and OPENROUTER_API_KEY is used as fallback.
#
# OPENROUTER_API_KEY  →  fallback inference key.
#   Used for LLM calls when a tenant has no provisioned sub-key yet.
OPENROUTER_MANAGER_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://ignify.ai
OPENROUTER_APP_NAME=Ignify

# ─── AI Providers (direct — optional, fallback to OpenRouter) ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Media Generation ───────────────────────────────────────
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=

# ─── Social Platform OAuth ──────────────────────────────────
# One app per platform, registered by YOU (the operator).
# Tenants click "Connect" in the dashboard and authorize against YOUR app.
# Full setup guide: docs/SOCIAL_PLATFORM_SETUP.md

# Meta (Facebook + Instagram) — https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/social-scheduler/oauth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=ignify-webhook-verify-token-change-me

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/social-scheduler/oauth/linkedin/callback

# X (Twitter) — posting requires Basic tier ($200/mo) — https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/api/v1/social-scheduler/oauth/x/callback

# YouTube — separate OAuth client from Google SEO (isolate scopes)
# https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/social-scheduler/oauth/youtube/callback

# TikTok — needs app review for video.publish scope — https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/v1/social-scheduler/oauth/tiktok/callback

# Snapchat — Login Kit only, no public posting API — https://kit.snapchat.com/portal
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=http://localhost:8000/api/v1/social-scheduler/oauth/snapchat/callback

# ─── Google OAuth (Search Console + Analytics 4) ────────────
# Separate client from YouTube — different scopes.
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/seo/integrations/oauth/google/callback
GOOGLE_OAUTH_POST_REDIRECT=http://localhost:3000/ar/seo/my-site

# ─── Billing — Stripe ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Billing — Paymob (Egypt) ───────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ─── Billing — PayTabs (MENA) ───────────────────────────────
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_REGION=EGY
PAYTABS_BASE_URL=https://secure-egypt.paytabs.com

# ─── Billing — Geidea (Pay by Link) ─────────────────────────
GEIDEA_PUBLIC_KEY=
GEIDEA_API_PASSWORD=
GEIDEA_MERCHANT_ID=
GEIDEA_BASE_URL=https://api.merchant.geidea.net

# ─── Billing URLs ────────────────────────────────────────────
BILLING_SUCCESS_URL=http://localhost:3000/billing/success
BILLING_CANCEL_URL=http://localhost:3000/billing/cancel
BILLING_CALLBACK_BASE=http://localhost:8000

# ─── SEO / SERP Providers (optional) ────────────────────────
SERPER_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# ─── Ad Platform APIs (optional) ─────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─── Observability ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO
