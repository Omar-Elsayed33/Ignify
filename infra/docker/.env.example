# ============================================================
# IGNIFY - Development Environment Configuration
# ============================================================

# ─── Database ───
POSTGRES_USER=ignify
POSTGRES_PASSWORD=ignify_dev_2024
POSTGRES_DB=ignify
DATABASE_URL=postgresql+asyncpg://ignify:ignify_dev_2024@postgres:5432/ignify

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── App Mode ───
DEBUG=true

# ─── Security ───
SECRET_KEY=dev-only-secret-key-change-in-production-64-chars-aaaaaabbbbbbcccccc

# ─── AI Runtime ───
AGNO_RUNTIME_URL=http://agno-runtime:8001

# ─── Storage (MinIO) ───
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=ignify
MINIO_SECRET_KEY=ignify_minio_2024
MINIO_BUCKET=ignify-assets

# ─── CORS ───
CORS_ORIGINS=["http://localhost:3000","http://localhost:3010","http://localhost:80","http://localhost:8000"]

# ─── Celery ───
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Ignify
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# ─── AI Providers (optional - add your keys to enable AI features) ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Ad Platform APIs (optional - add when ready) ───
GOOGLE_ADS_DEVELOPER_TOKEN=
META_APP_ID=
META_APP_SECRET=
SNAPCHAT_APP_ID=
SNAPCHAT_APP_SECRET=
