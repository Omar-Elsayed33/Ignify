# ============================================================
# IGNIFY - Development Environment Configuration
# ============================================================

# ─── Database ───
POSTGRES_USER=ignify
POSTGRES_PASSWORD=ignify_dev_2024
POSTGRES_DB=ignify
DATABASE_URL=postgresql+asyncpg://ignify:ignify_dev_2024@postgres:5432/ignify

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── App Mode ───
DEBUG=true

# ─── Security ───
SECRET_KEY=dev-only-secret-key-change-in-production-64-chars-aaaaaabbbbbbcccccc

# ─── Storage (MinIO) ───
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=ignify
MINIO_SECRET_KEY=ignify_minio_2024
MINIO_BUCKET=ignify-assets

# ─── CORS ───
CORS_ORIGINS=["http://localhost:3000","http://localhost:3010","http://localhost:80","http://localhost:8000"]

# ─── Celery ───
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Ignify
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# ─── AI Providers (optional - add your keys to enable AI features) ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── LLM Gateway (OpenRouter) — REQUIRED for AI features ───
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://ignify.ai
OPENROUTER_APP_NAME=Ignify

# ─── Media Providers ───
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=

# ─── Meta OAuth (Facebook + Instagram) ───
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/social-scheduler/oauth/meta/callback

# ─── Billing - Stripe ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Billing - Paymob (Egypt) ───
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ─── Billing - PayTabs (MENA) ───
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_REGION=EGY
PAYTABS_BASE_URL=https://secure-egypt.paytabs.com

# ─── Billing - Geidea (Pay by Link) ───
GEIDEA_PUBLIC_KEY=
GEIDEA_API_PASSWORD=
GEIDEA_MERCHANT_ID=
GEIDEA_BASE_URL=https://api.merchant.geidea.net

# ─── Billing URLs ───
BILLING_SUCCESS_URL=http://localhost:3000/billing/success
BILLING_CANCEL_URL=http://localhost:3000/billing/cancel
BILLING_CALLBACK_BASE=http://localhost:8000

# ─── Observability ───
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO

# ─── Webhooks ───
META_WEBHOOK_VERIFY_TOKEN=ignify-webhook-verify-token-change-me

# ─── Ad Platform APIs (optional - add when ready) ───
GOOGLE_ADS_DEVELOPER_TOKEN=
SNAPCHAT_APP_ID=
SNAPCHAT_APP_SECRET=
