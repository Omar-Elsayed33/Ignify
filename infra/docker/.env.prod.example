# ============================================================
# IGNIFY — Production Environment Template
# Copy to .env.prod, fill ALL values, keep secret.
# Never commit .env.prod to git.
# ============================================================

# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=ignify
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_MIN_32_CHARS
POSTGRES_DB=ignify
DATABASE_URL=postgresql+asyncpg://ignify:CHANGE_ME_STRONG_DB_PASSWORD_MIN_32_CHARS@postgres:5432/ignify

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── App ────────────────────────────────────────────────────
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX_STRING

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["https://app.ignify.ai","https://ignify.ai"]

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.ignify.ai
NEXT_PUBLIC_APP_NAME=Ignify
NEXT_PUBLIC_DASHBOARD_URL=https://app.ignify.ai

# ─── Storage (MinIO or S3) ───────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET=ignify-assets
# For public asset URLs (CDN or public MinIO endpoint)
MINIO_PUBLIC_HOST=assets.ignify.ai

# ─── Email (SMTP) ───────────────────────────────────────────
# Use a transactional provider: SendGrid, Postmark, Mailgun, Amazon SES.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=Ignify <no-reply@ignify.ai>
EMAIL_VERIFICATION_REQUIRED=true
FRONTEND_URL=https://app.ignify.ai

# ─── LLM Gateway — OpenRouter ───────────────────────────────
# OPENROUTER_MANAGER_KEY  →  provisioning only ("Manage keys" permission).
#   Go to https://openrouter.ai/settings/keys, create a key, enable "Manage keys".
#   Used to create/update/delete per-tenant sub-keys. NEVER used for inference.
#
# OPENROUTER_API_KEY  →  fallback inference key.
#   Used for LLM calls when a tenant has no provisioned sub-key yet.
OPENROUTER_MANAGER_KEY=sk-or-v1-CHANGE_ME_MANAGER_KEY_WITH_MANAGE_KEYS_PERMISSION
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME_FALLBACK_INFERENCE_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://ignify.ai
OPENROUTER_APP_NAME=Ignify

# ─── AI Providers (direct — optional, fallback to OpenRouter) ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Media Generation ───────────────────────────────────────
REPLICATE_API_TOKEN=CHANGE_ME_REPLICATE_TOKEN
ELEVENLABS_API_KEY=CHANGE_ME_ELEVENLABS_KEY

# ─── Social Platform OAuth ──────────────────────────────────
# One app per platform, registered by YOU (the operator).
# Tenants click "Connect" and authorize against YOUR app.
# Full setup guide: docs/SOCIAL_PLATFORM_SETUP.md

# Meta (Facebook + Instagram) — https://developers.facebook.com/apps
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME
META_REDIRECT_URI=https://api.ignify.ai/api/v1/social-scheduler/oauth/meta/callback
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
META_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_RANDOM_TOKEN

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=CHANGE_ME
LINKEDIN_CLIENT_SECRET=CHANGE_ME
LINKEDIN_REDIRECT_URI=https://api.ignify.ai/api/v1/social-scheduler/oauth/linkedin/callback

# X (Twitter) — posting requires Basic tier ($200/mo) — https://developer.x.com
X_CLIENT_ID=CHANGE_ME
X_CLIENT_SECRET=CHANGE_ME
X_REDIRECT_URI=https://api.ignify.ai/api/v1/social-scheduler/oauth/x/callback

# YouTube — separate OAuth client from Google SEO (isolate scopes)
# https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=CHANGE_ME
YOUTUBE_CLIENT_SECRET=CHANGE_ME
YOUTUBE_REDIRECT_URI=https://api.ignify.ai/api/v1/social-scheduler/oauth/youtube/callback

# TikTok — needs app review for video.publish scope — https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=CHANGE_ME
TIKTOK_CLIENT_SECRET=CHANGE_ME
TIKTOK_REDIRECT_URI=https://api.ignify.ai/api/v1/social-scheduler/oauth/tiktok/callback

# Snapchat — Login Kit only, no public posting API — https://kit.snapchat.com/portal
SNAPCHAT_CLIENT_ID=CHANGE_ME
SNAPCHAT_CLIENT_SECRET=CHANGE_ME
SNAPCHAT_REDIRECT_URI=https://api.ignify.ai/api/v1/social-scheduler/oauth/snapchat/callback

# ─── Google OAuth (Search Console + Analytics 4) ────────────
# Separate client from YouTube — different scopes.
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME
GOOGLE_OAUTH_REDIRECT_URI=https://api.ignify.ai/api/v1/seo/integrations/oauth/google/callback
GOOGLE_OAUTH_POST_REDIRECT=https://app.ignify.ai/ar/seo/my-site

# ─── Billing — Stripe ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ─── Billing — Paymob (Egypt) ───────────────────────────────
PAYMOB_API_KEY=CHANGE_ME
PAYMOB_INTEGRATION_ID=CHANGE_ME
PAYMOB_IFRAME_ID=CHANGE_ME
PAYMOB_HMAC_SECRET=CHANGE_ME

# ─── Billing — PayTabs (MENA) ───────────────────────────────
PAYTABS_PROFILE_ID=CHANGE_ME
PAYTABS_SERVER_KEY=CHANGE_ME
PAYTABS_REGION=EGY
PAYTABS_BASE_URL=https://secure-egypt.paytabs.com

# ─── Billing — Geidea (Pay by Link) ─────────────────────────
GEIDEA_PUBLIC_KEY=CHANGE_ME
GEIDEA_API_PASSWORD=CHANGE_ME
GEIDEA_MERCHANT_ID=CHANGE_ME
GEIDEA_BASE_URL=https://api.merchant.geidea.net

# ─── Billing URLs ────────────────────────────────────────────
BILLING_SUCCESS_URL=https://app.ignify.ai/billing/success
BILLING_CANCEL_URL=https://app.ignify.ai/billing/cancel
BILLING_CALLBACK_BASE=https://api.ignify.ai

# ─── SEO / SERP Providers (optional) ────────────────────────
SERPER_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
GOOGLE_CSE_ID=
GOOGLE_CSE_API_KEY=

# ─── Ad Platform APIs (optional) ─────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=

# ─── Observability ───────────────────────────────────────────
# Sentry: https://sentry.io — create a project, copy the DSN.
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
LOG_LEVEL=WARNING

# ─── Domain (for reverse proxy / Let's Encrypt) ──────────────
APP_HOST=ignify.ai
LETSENCRYPT_EMAIL=admin@ignify.ai
