# ============================================================
# IGNIFY - Production Environment Configuration
# Copy to .env.prod and fill in real values
# ============================================================

# ─── Database ───
POSTGRES_USER=ignify
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ignify

# ─── App ───
DEBUG=false
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX_STRING_HERE_ABCDEF1234567890ABCDEF

# ─── Storage ───
MINIO_ACCESS_KEY=ignify
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# ─── CORS ───
CORS_ORIGINS=["https://app.yourdomain.com","https://yourdomain.com"]

# ─── AI Providers ───
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=

# ─── Domain ───
APP_HOST=yourdomain.com
LETSENCRYPT_EMAIL=admin@yourdomain.com
