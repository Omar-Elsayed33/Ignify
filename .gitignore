# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Environment
.env
.env.local
.env.production
*.env
# Catches .env.prod, .env.staging, .env.anything — *.env above only matches
# files ending in `.env`, not files ending in `.env.<suffix>`. The two
# patterns together cover both shapes.
.env.*
# Re-allow committed *.example placeholder files. They contain only
# placeholders (no real secrets), and they're the canonical reference for
# what env vars exist.
!.env.example
!.env.*.example

# Build
.next/
out/
dist/
build/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker volumes
postgres_data/
redis_data/
minio_data/

# WhatsApp sessions
sessions/

# Logs
*.log
logs/

# Coverage
coverage/
.coverage
htmlcov/

# Misc
*.bak
*.tmp
